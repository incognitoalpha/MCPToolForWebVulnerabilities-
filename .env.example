# Gemini API Configuration (for all AI features)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.2

# NVD API Configuration (optional - for CVE enrichment)
# Get your free API key at: https://nvd.nist.gov/developers/request-an-api-key
# Without key: 5 requests/30s | With key: 50 requests/30s (10x faster)
NVD_API_KEY=

# Session Storage
SESSION_DIR=~/.pentest-mcp/sessions

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Agent Settings (for standalone CLI mode with "pentest ask")
AGENT_MAX_TOOLS=10

# Local fine-tuned model (Ollama)
LOCAL_MODEL_ENABLED=true
LOCAL_MODEL_NAME=pentest-ai          # name you gave it in: ollama create pentest-ai -f Modelfile
OLLAMA_BASE_URL=http://localhost:11434

# Set to false to always use Gemini for reports (useful in CI/CD)
# LOCAL_MODEL_ENABLED=false