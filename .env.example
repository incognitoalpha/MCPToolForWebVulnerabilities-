# Groq API Configuration (for MCP server analysis)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=8192
GROQ_TEMPERATURE=0.2

# Gemini API Configuration (for standalone CLI agent mode)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-lite-latest
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.2

# Session Storage
SESSION_DIR=~/.pentest-mcp/sessions

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Agent Settings (for standalone CLI mode with "pentest ask")
AGENT_MAX_TOOLS=10
