# Gemini API Configuration (for all AI features)
# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-lite-latest
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.2

# NVD API Key (for CVE enrichment)
# Get your API key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# Session Storage
SESSION_DIR=~/.pentest-mcp/sessions

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Agent Settings
AGENT_MAX_TOOLS=10

# Local Model Settings (Ollama) - OPTIONAL/EXPERIMENTAL
# The fine-tuned model training notebook: FineTuning.ipynb
#
# RECOMMENDED: Keep this FALSE - Gemini produces better quality reports
# Set to TRUE only if you want to experiment with local model
LOCAL_MODEL_ENABLED=false
LOCAL_MODEL_NAME=pentest-ai-1.5b
OLLAMA_BASE_URL=http://localhost:11434
