# Gemini API Configuration (for all AI features)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-lite-latest
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.2

# Session Storage
SESSION_DIR=~/.pentest-ai/sessions

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Agent Settings (for standalone CLI mode with "pentest ask")
AGENT_MAX_TOOLS=10
