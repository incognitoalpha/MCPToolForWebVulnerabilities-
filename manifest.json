{
  "version": "1.0.0",
  "tools": [
    {
      "name": "ping",
      "description": "Health check for the PenTest MCP server",
      "input_schema": {
        "type": "object",
        "properties": {}
      },
      "version": "1.0.0"
    },
    {
      "name": "init_session",
      "description": "Initialize new security assessment session",
      "input_schema": {
        "type": "object",
        "properties": {
          "target": {"type": "string", "description": "Target URL or domain"}
        },
        "required": ["target"]
      },
      "version": "1.0.0"
    },
    {
      "name": "get_report",
      "description": "Generate final security assessment report",
      "input_schema": {
        "type": "object",
        "properties": {
          "session_id": {"type": "string", "description": "Session identifier"}
        },
        "required": ["session_id"]
      },
      "version": "1.0.0"
    },
    {
      "name": "environment_check",
      "description": "Inspect installed tools, missing dependencies, and assessment readiness",
      "input_schema": {
        "type": "object",
        "properties": {}
      },
      "version": "1.0.0"
    },
    {
      "name": "quick_scan",
      "description": "Fast triage scan (10-15 min): WAF detection, subdomain enum, top-port scan, header analysis, TLS audit, tech fingerprinting, sensitive file discovery, SSRF probe, CSRF check",
      "input_schema": {
        "type": "object",
        "properties": {
          "target": {"type": "string", "description": "Target URL"},
          "consent": {"type": "boolean", "description": "Explicit consent for active scanning"}
        },
        "required": ["target", "consent"]
      },
      "version": "1.0.0"
    },
    {
      "name": "extensive_scan",
      "description": "Comprehensive scan (20-45 min): WAF detection, full recon, top-1000 port scan, tech fingerprinting, TLS audit, directory discovery, XSS, SQLi, CSRF, sensitive file discovery",
      "input_schema": {
        "type": "object",
        "properties": {
          "target": {"type": "string", "description": "Target URL"},
          "consent": {"type": "boolean", "description": "Explicit consent for active scanning"}
        },
        "required": ["target", "consent"]
      },
      "version": "1.0.0"
    },
    {
      "name": "subfinder",
      "description": "Passive subdomain enumeration",
      "input_schema": {
        "type": "object",
        "properties": {
          "domain": {"type": "string"},
          "session_id": {"type": "string"},
          "consent": {"type": "boolean", "default": false}
        },
        "required": ["domain", "session_id"]
      },
      "version": "1.0.0"
    },
    {
      "name": "wafw00f",
      "description": "Web Application Firewall detection",
      "input_schema": {
        "type": "object",
        "properties": {
          "url": {"type": "string"},
          "session_id": {"type": "string"}
        },
        "required": ["url", "session_id"]
      },
      "version": "1.0.0"
    },
    {
      "name": "nmap",
      "description": "Port scanning and service detection",
      "input_schema": {
        "type": "object",
        "properties": {
          "host": {"type": "string"},
          "session_id": {"type": "string"},
          "ports": {"type": "array", "items": {"type": "integer"}, "default": null},
          "consent": {"type": "boolean", "default": false}
        },
        "required": ["host", "session_id"]
      },
      "version": "1.0.0"
    },
    {
      "name": "nuclei",
      "description": "Fast vulnerability scanner with templates",
      "input_schema": {
        "type": "object",
        "properties": {
          "url": {"type": "string"},
          "session_id": {"type": "string"}
        },
        "required": ["url", "session_id"]
      },
      "version": "1.0.0"
    },
    {
      "name": "sqlmap",
      "description": "SQL injection detection and exploitation",
      "input_schema": {
        "type": "object",
        "properties": {
          "url": {"type": "string"},
          "session_id": {"type": "string"},
          "params": {"type": "array", "items": {"type": "string"}, "default": null},
          "consent": {"type": "boolean", "default": false}
        },
        "required": ["url", "session_id"]
      },
      "version": "1.0.0"
    },
    {
      "name": "dalfox",
      "description": "XSS vulnerability scanner",
      "input_schema": {
        "type": "object",
        "properties": {
          "url": {"type": "string"},
          "session_id": {"type": "string"},
          "params": {"type": "array", "items": {"type": "string"}, "default": null},
          "consent": {"type": "boolean", "default": false}
        },
        "required": ["url", "session_id"]
      },
      "version": "1.0.0"
    },
