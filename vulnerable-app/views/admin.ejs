<!DOCTYPE html>
<html>
<head>
  <title>Admin Dashboard - VulnLab</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Arial, sans-serif; background: #1a1a2e; color: #eee; }
    .nav { background: #16213e; padding: 15px 30px; display: flex; justify-content: space-between; align-items: center; }
    .nav a { color: #e94560; text-decoration: none; margin-left: 20px; }
    .nav .brand { font-size: 1.5em; font-weight: bold; color: #e94560; }
    .container { max-width: 1000px; margin: 30px auto; padding: 0 20px; }
    .admin-card { background: #16213e; border-radius: 8px; padding: 40px; border-left: 8px solid #ffeb3b; }
    .admin-card h1 { color: #ffeb3b; margin-bottom: 20px; }
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px; }
    .stat-box { background: #0f3460; padding: 20px; border-radius: 8px; text-align: center; border: 1px solid #333; }
    .stat-box .number { font-size: 2.5em; font-weight: bold; color: #ffeb3b; display: block; }
    .stat-box .label { color: #888; font-size: 0.9em; margin-top: 5px; }
    table { width: 100%; border-collapse: collapse; margin-top: 20px; background: #0f3460; border-radius: 8px; overflow: hidden; }
    th, td { padding: 15px; text-align: left; border-bottom: 1px solid #16213e; }
    th { background: #1a1a2e; color: #ffeb3b; font-weight: bold; }
    tr:hover { background: #16213e; }
    .role-badge { padding: 4px 8px; border-radius: 4px; font-size: 0.8em; font-weight: bold; text-transform: uppercase; }
    .role-admin { background: #ffeb3b; color: #000; }
    .role-user { background: #e94560; color: #fff; }
    .warning-banner { background: #e94560; color: #fff; text-align: center; padding: 8px; font-size: 0.85em; }
    .unauthorized-msg { background: #ffeb3b; color: #000; padding: 15px; border-radius: 6px; margin-bottom: 20px; text-align: center; }
  </style>
</head>
<body>
  <div class="warning-banner">⚠️ DELIBERATELY VULNERABLE - FOR TESTING ONLY ⚠️</div>
  <nav class="nav">
    <span class="brand">🔓 VulnLab</span>
    <div>
      <a href="/">Home</a>
      <a href="/search?q=">Search</a>
      <a href="/tools/ping">Ping Tool</a>
      <a href="/admin">Admin</a>
      <% if (user) { %>
        <a href="/profile/<%= user.id %>">Profile</a>
        <a href="/logout">Logout (<%= user.username %>)</a>
      <% } else { %>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
      <% } %>
    </div>
  </nav>
  <div class="container">
    <div class="admin-card">
      <h1>⭐ Admin Control Panel</h1>
      
      <!-- VULNERABILITY: Broken Access Control (This entire page is accessible without admin token) -->
      <div class="unauthorized-msg">
        <b>💡 Security Insight:</b> This page lacks proper access control. Anyone can visit <code>/admin</code>.
      </div>
      
      <div class="stats-grid">
        <div class="stat-box">
          <span class="number"><%= stats.users %></span>
          <span class="label">Total Users</span>
        </div>
        <div class="stat-box">
          <span class="number"><%= stats.posts %></span>
          <span class="label">Total Posts</span>
        </div>
        <div class="stat-box">
          <span class="number"><%= stats.comments %></span>
          <span class="label">Total Comments</span>
        </div>
        <div class="stat-box">
          <span class="number">10.2GB</span>
          <span class="label">Database Size</span>
        </div>
      </div>
      
      <h3>System Users</h3>
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Username</th>
            <th>Email</th>
            <th>Role</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
            <tr>
              <td><%= u.id %></td>
              <td><%= u.username %></td>
              <td><%= u.email %></td>
              <td>
                <span class="role-badge role-<%= u.role %>">
                  <%= u.role %>
                </span>
              </td>
              <td>
                <button style="background: transparent; color: #ffeb3b; border: 1px solid #ffeb3b; padding: 5px 10px; font-size: 0.8em;">Edit</button>
                <button style="background: transparent; color: #ff4444; border: 1px solid #ff4444; padding: 5px 10px; font-size: 0.8em; margin-left: 5px;">Delete</button>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
