<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>🔓 Profile Dashboard | VulnLab</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Orbitron:wght@500;700;900&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-dark: #0a0b10;
      --panel-dark: #12131c;
      --accent-neon: #00f0ff;
      --accent-pink: #ff007f;
      --text-main: #e2e8f0;
      --text-muted: #64748b;
      --border-color: #27273a;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Inter', sans-serif;
    }

    body {
      background-color: var(--bg-dark);
      color: var(--text-main);
      min-height: 100vh;
    }

    header {
      border-bottom: 1px solid var(--border-color);
      background-color: rgba(18, 19, 28, 0.8);
      backdrop-filter: blur(12px);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 15px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .brand {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.6rem;
      font-weight: 900;
      letter-spacing: 2px;
      color: var(--accent-neon);
      text-decoration: none;
    }

    .brand span {
      color: var(--accent-pink);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 25px;
    }

    .nav-links a {
      color: var(--text-main);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.95rem;
      transition: all 0.3s ease;
    }

    .nav-links a:hover {
      color: var(--accent-neon);
    }

    .container {
      max-width: 800px;
      margin: 40px auto;
      padding: 0 20px;
    }

    .profile-card {
      background: var(--panel-dark);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 40px;
      position: relative;
      overflow: hidden;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
    }

    .profile-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, var(--accent-neon), var(--accent-pink));
    }

    .profile-title {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.8rem;
      font-weight: 900;
      color: var(--accent-neon);
      margin-bottom: 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .profile-badge {
      font-size: 0.8rem;
      background: rgba(0, 240, 255, 0.1);
      border: 1px solid var(--accent-neon);
      padding: 4px 12px;
      border-radius: 20px;
      text-transform: uppercase;
    }

    .info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 30px;
    }

    @media (max-width: 600px) {
      .info-grid {
        grid-template-columns: 1fr;
      }
    }

    .info-item {
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 12px;
    }

    .info-label {
      font-size: 0.8rem;
      color: var(--text-muted);
      text-transform: uppercase;
      margin-bottom: 4px;
    }

    .info-value {
      font-weight: 600;
    }

    .info-value-sensitive {
      font-family: monospace;
      color: var(--accent-pink);
    }

    .update-section {
      border-top: 1px solid var(--border-color);
      padding-top: 30px;
    }

    .update-title {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 20px;
    }

    .cyber-input {
      width: 100%;
      background: rgba(0, 0, 0, 0.2);
      border: 1px solid var(--border-color);
      color: var(--text-main);
      padding: 12px 16px;
      border-radius: 8px;
      font-size: 0.95rem;
      outline: none;
      transition: all 0.3s ease;
      min-height: 100px;
      resize: vertical;
    }

    .cyber-input:focus {
      border-color: var(--accent-neon);
    }

    .cyber-button {
      background: var(--accent-neon);
      color: var(--bg-dark);
      border: none;
      padding: 12px 24px;
      border-radius: 8px;
      font-weight: 700;
      cursor: pointer;
      font-family: 'Orbitron', sans-serif;
      transition: all 0.3s ease;
      margin-top: 15px;
    }

    .cyber-button:hover {
      box-shadow: 0 0 15px rgba(0, 240, 255, 0.4);
    }

    .idor-alert {
      background: rgba(255, 0, 127, 0.1);
      border: 1px solid var(--accent-pink);
      color: var(--accent-pink);
      padding: 15px;
      border-radius: 8px;
      font-size: 0.85rem;
      margin-top: 30px;
      line-height: 1.5;
    }
  </style>
</head>
<body>
  <header>
    <div class="header-container">
      <a href="/" class="brand">🔓 VULN<span>LAB</span></a>
      <nav class="nav-links">
        <a href="/">Home</a>
        <a href="/search?q=">Search</a>
        <a href="/tools/ping">Ping System</a>
        <a href="/admin">Admin Control</a>
      </nav>
    </div>
  </header>

  <div class="container">
    <div class="profile-card">
      <h1 class="profile-title">
        User Profile
        <span class="profile-badge"><%= profile.role %></span>
      </h1>

      <div class="info-grid">
        <div class="info-item">
          <div class="info-label">User Identity ID</div>
          <div class="info-value"><%= profile.id %></div>
        </div>
        <div class="info-item">
          <div class="info-label">Username Handle</div>
          <div class="info-value"><%= profile.username %></div>
        </div>
        <div class="info-item">
          <div class="info-label">Secure Contact Mail</div>
          <div class="info-value"><%= profile.email %></div>
        </div>
        <div class="info-item">
          <div class="info-label">Access Token / API Key (Leaked)</div>
          <div class="info-value-sensitive"><%= profile.api_key || 'UNASSIGNED_KEY' %></div>
        </div>
      </div>

      <div class="info-item" style="margin-bottom: 30px;">
        <div class="info-label">Biography Status (Stored XSS Trigger)</div>
        <div class="info-value"><%- profile.bio || '<i>No bio set.</i>' %></div>
      </div>

      <% if (user && user.id === profile.id) { %>
        <div class="update-section">
          <h2 class="update-title">Update Status (No Sanitization)</h2>
          <form method="POST" action="/profile/update">
            <textarea name="bio" class="cyber-input" placeholder="Type custom status bio... html/scripts permitted..."><%= profile.bio %></textarea>
            <button type="submit" class="cyber-button">Update Bio</button>
          </form>
        </div>
      <% } %>

      <div class="idor-alert">
        <strong>💡 IDOR Testing Sandbox:</strong> Increment or decrement the user ID in the address bar (e.g., <code>/profile/1</code>, <code>/profile/2</code>) to view private profiles, leaked emails, and critical API tokens without any authorization gates!
      </div>
    </div>
  </div>
</body>
</html>
