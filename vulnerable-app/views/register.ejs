<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>🔓 Register | VulnLab Range</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Orbitron:wght@500;700;900&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-dark: #0a0b10;
      --panel-dark: #12131c;
      --accent-neon: #00f0ff;
      --accent-pink: #ff007f;
      --text-main: #e2e8f0;
      --text-muted: #64748b;
      --border-color: #27273a;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Inter', sans-serif;
    }

    body {
      background-color: var(--bg-dark);
      color: var(--text-main);
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      padding: 20px;
    }

    .register-container {
      background: var(--panel-dark);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      width: 100%;
      max-width: 440px;
      padding: 40px;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
      position: relative;
      overflow: hidden;
    }

    .register-container::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, var(--accent-neon), var(--accent-pink));
    }

    .register-header {
      text-align: center;
      margin-bottom: 30px;
    }

    .register-logo {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.8rem;
      font-weight: 900;
      color: var(--accent-neon);
      letter-spacing: 2px;
      margin-bottom: 10px;
    }

    .register-logo span {
      color: var(--accent-pink);
    }

    .register-subtitle {
      color: var(--text-muted);
      font-size: 0.9rem;
    }

    .form-group {
      margin-bottom: 20px;
    }

    .form-label {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      margin-bottom: 8px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .cyber-input {
      width: 100%;
      background: rgba(0, 0, 0, 0.2);
      border: 1px solid var(--border-color);
      color: var(--text-main);
      padding: 12px 16px;
      border-radius: 8px;
      font-size: 0.95rem;
      outline: none;
      transition: all 0.3s ease;
    }

    .cyber-input:focus {
      border-color: var(--accent-neon);
      box-shadow: 0 0 10px rgba(0, 240, 255, 0.15);
    }

    .cyber-button {
      width: 100%;
      background: linear-gradient(90deg, var(--accent-neon), #00a8ff);
      color: var(--bg-dark);
      border: none;
      padding: 14px;
      border-radius: 8px;
      font-weight: 700;
      cursor: pointer;
      font-family: 'Orbitron', sans-serif;
      transition: all 0.3s ease;
      font-size: 1rem;
      margin-top: 10px;
    }

    .cyber-button:hover {
      box-shadow: 0 0 20px rgba(0, 240, 255, 0.4);
      transform: translateY(-1px);
    }

    .error-banner {
      background: rgba(255, 0, 127, 0.1);
      border: 1px solid var(--accent-pink);
      color: var(--accent-pink);
      padding: 12px;
      border-radius: 8px;
      margin-bottom: 20px;
      font-size: 0.85rem;
      line-height: 1.5;
    }

    .login-link {
      text-align: center;
      margin-top: 25px;
      font-size: 0.85rem;
      color: var(--text-muted);
    }

    .login-link a {
      color: var(--accent-neon);
      text-decoration: none;
      font-weight: 600;
      transition: color 0.2s ease;
    }

    .login-link a:hover {
      color: var(--accent-pink);
    }
  </style>
</head>
<body>
  <div class="register-container">
    <div class="register-header">
      <div class="register-logo">🔓 VULN<span>LAB</span></div>
      <div class="register-subtitle">Target Registration Portal</div>
    </div>

    <% if (error) { %>
      <div class="error-banner">
        <strong>Registration Error Context:</strong><br>
        <%- error %>
      </div>
    <% } %>

    <form method="POST" action="/register">
      <div class="form-group">
        <label class="form-label">User Identity</label>
        <input type="text" name="username" class="cyber-input" placeholder="Desired username..." required autofocus>
      </div>

      <div class="form-group">
        <label class="form-label">Email Address</label>
        <input type="email" name="email" class="cyber-input" placeholder="Your test email..." required>
      </div>

      <div class="form-group">
        <label class="form-label">Credentials Passphrase</label>
        <input type="password" name="password" class="cyber-input" placeholder="Create secure password..." required>
      </div>

      <button type="submit" class="cyber-button">Generate Account</button>
    </form>

    <div class="login-link">
      Already have a target account? <a href="/login">Authenticate Here</a>
    </div>
  </div>
</body>
</html>
