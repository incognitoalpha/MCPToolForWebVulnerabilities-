<!DOCTYPE html>
<html>
<head>
  <title><%= post.title %> - VulnLab</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Arial, sans-serif; background: #1a1a2e; color: #eee; }
    .nav { background: #16213e; padding: 15px 30px; display: flex; justify-content: space-between; align-items: center; }
    .nav a { color: #e94560; text-decoration: none; margin-left: 20px; }
    .nav .brand { font-size: 1.5em; font-weight: bold; color: #e94560; }
    .container { max-width: 900px; margin: 30px auto; padding: 0 20px; }
    .post-content { background: #16213e; border-radius: 8px; padding: 40px; margin-bottom: 40px; border-left: 8px solid #e94560; }
    .post-content h1 { color: #e94560; margin-bottom: 10px; }
    .post-content .meta { color: #888; font-size: 0.9em; margin-bottom: 20px; }
    .post-content .body { line-height: 1.8; font-size: 1.1em; }
    .comments-section { background: #16213e; border-radius: 8px; padding: 30px; }
    .comment { border-bottom: 1px solid #333; padding: 15px 0; }
    .comment:last-child { border-bottom: none; }
    .comment .username { font-weight: bold; color: #e94560; }
    .comment .date { font-size: 0.8em; color: #888; margin-left: 10px; }
    .comment-form { margin-top: 30px; padding-top: 20px; border-top: 1px solid #333; }
    textarea { width: 100%; padding: 12px; border-radius: 6px; border: 1px solid #333; background: #0f3460; color: #eee; font-size: 1em; margin-bottom: 10px; height: 80px; }
    button { padding: 10px 20px; background: #e94560; color: #fff; border: none; border-radius: 6px; cursor: pointer; }
    .warning-banner { background: #e94560; color: #fff; text-align: center; padding: 8px; font-size: 0.85em; }
  </style>
</head>
<body>
  <div class="warning-banner">⚠️ DELIBERATELY VULNERABLE - FOR TESTING ONLY ⚠️</div>
  <nav class="nav">
    <span class="brand">🔓 VulnLab</span>
    <div>
      <a href="/">Home</a>
      <a href="/search?q=">Search</a>
      <a href="/tools/ping">Ping Tool</a>
      <a href="/admin">Admin</a>
      <% if (user) { %>
        <a href="/profile/<%= user.id %>">Profile</a>
        <a href="/logout">Logout (<%= user.username %>)</a>
      <% } else { %>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
      <% } %>
    </div>
  </nav>
  <div class="container">
    <div class="post-content">
      <h1><%= post.title %></h1>
      <div class="meta">By <a href="/profile/1" style="color: #e94560; text-decoration: none;"><%= post.username %></a> | <%= post.created_at %></div>
      <div class="body">
        <%= post.content %>
      </div>
    </div>
    
    <div class="comments-section">
      <h3>Comments</h3>
      <div id="comments">
        <% if (comments.length === 0) { %>
          <p style="color: #888; margin-top: 10px;">No comments yet. Be the first!</p>
        <% } %>
        <% comments.forEach(comment => { %>
          <div class="comment">
            <span class="username"><%= comment.username %></span>
            <span class="date"><%= comment.created_at %></span>
            
            <!-- VULNERABILITY: Stored XSS (Comment body reflected without encoding) -->
            <div style="margin-top: 8px; line-height: 1.6;">
              <%- comment.content %>
            </div>
          </div>
        <% }); %>
      </div>
      
      <% if (user) { %>
        <div class="comment-form">
          <form action="/post/<%= post.id %>/comment" method="POST">
            <textarea name="content" placeholder="Write a comment..." required></textarea>
            <button type="submit">Post Comment</button>
          </form>
          <p style="margin-top: 10px; font-size: 0.8em; color: #888;">💡 HTML is supported in comments!</p>
        </div>
      <% } else { %>
        <p style="margin-top: 20px; color: #888;"><a href="/login" style="color: #e94560;">Login</a> to leave a comment.</p>
      <% } %>
    </div>
  </div>
</body>
</html>
