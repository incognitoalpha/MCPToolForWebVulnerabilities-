<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>🔓 Post Detail | VulnLab</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Orbitron:wght@500;700;900&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-dark: #0a0b10;
      --panel-dark: #12131c;
      --accent-neon: #00f0ff;
      --accent-pink: #ff007f;
      --text-main: #e2e8f0;
      --text-muted: #64748b;
      --border-color: #27273a;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Inter', sans-serif;
    }

    body {
      background-color: var(--bg-dark);
      color: var(--text-main);
      min-height: 100vh;
    }

    header {
      border-bottom: 1px solid var(--border-color);
      background-color: rgba(18, 19, 28, 0.8);
      backdrop-filter: blur(12px);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 15px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .brand {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.6rem;
      font-weight: 900;
      letter-spacing: 2px;
      color: var(--accent-neon);
      text-decoration: none;
    }

    .brand span {
      color: var(--accent-pink);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 25px;
    }

    .nav-links a {
      color: var(--text-main);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.95rem;
      transition: all 0.3s ease;
    }

    .nav-links a:hover {
      color: var(--accent-neon);
    }

    .container {
      max-width: 800px;
      margin: 40px auto;
      padding: 0 20px;
    }

    .post-card {
      background: var(--panel-dark);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 40px;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
      position: relative;
      overflow: hidden;
      margin-bottom: 30px;
    }

    .post-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, var(--accent-neon), var(--accent-pink));
    }

    .post-title {
      font-size: 1.8rem;
      font-weight: 700;
      margin-bottom: 15px;
    }

    .post-body {
      color: var(--text-muted);
      line-height: 1.6;
      font-size: 1rem;
      margin-bottom: 25px;
    }

    .post-meta {
      font-size: 0.85rem;
      color: var(--text-muted);
      border-top: 1px solid var(--border-color);
      padding-top: 15px;
      margin-bottom: 30px;
    }

    .post-meta span strong {
      color: #fff;
    }

    .comment-section {
      border-top: 1px solid var(--border-color);
      padding-top: 30px;
    }

    .comment-title {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 20px;
    }

    .comment-form {
      margin-bottom: 30px;
    }

    .cyber-input {
      width: 100%;
      background: rgba(0, 0, 0, 0.2);
      border: 1px solid var(--border-color);
      color: var(--text-main);
      padding: 12px 16px;
      border-radius: 8px;
      font-size: 0.95rem;
      outline: none;
      transition: all 0.3s ease;
      min-height: 80px;
      resize: vertical;
      margin-bottom: 10px;
    }

    .cyber-input:focus {
      border-color: var(--accent-neon);
    }

    .cyber-button {
      background: var(--accent-neon);
      color: var(--bg-dark);
      border: none;
      padding: 10px 20px;
      border-radius: 8px;
      font-weight: 700;
      cursor: pointer;
      font-family: 'Orbitron', sans-serif;
      transition: all 0.3s ease;
    }

    .cyber-button:hover {
      box-shadow: 0 0 15px rgba(0, 240, 255, 0.4);
    }

    .comment-card {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 20px;
      margin-bottom: 15px;
    }

    .comment-author {
      font-weight: 600;
      font-size: 0.9rem;
      color: var(--accent-neon);
      margin-bottom: 5px;
    }

    .comment-content {
      font-size: 0.9rem;
      line-height: 1.5;
    }
  </style>
</head>
<body>
  <header>
    <div class="header-container">
      <a href="/" class="brand">🔓 VULN<span>LAB</span></a>
      <nav class="nav-links">
        <a href="/">Home</a>
        <a href="/search?q=">Search</a>
        <a href="/tools/ping">Ping System</a>
        <a href="/admin">Admin Control</a>
      </nav>
    </div>
  </header>

  <div class="container">
    <article class="post-card">
      <h1 class="post-title"><%= post.title %></h1>
      <p class="post-body"><%= post.content %></p>
      
      <div class="post-meta">
        <span>Author Profile: <strong><%= post.username %></strong></span> &nbsp;|&nbsp;
        <span>Timestamp: <strong><%= post.created_at %></strong></span>
      </div>

      <section class="comment-section">
        <h2 class="comment-title">Audience Feedback</h2>

        <% if (user) { %>
          <form method="POST" action="/post/<%= post.id %>/comment" class="comment-form">
            <textarea name="content" class="cyber-input" placeholder="Submit un-sanitized comment content (Stored XSS trigger)..." required></textarea>
            <button type="submit" class="cyber-button">Submit Comment</button>
          </form>
        <% } else { %>
          <p style="margin-bottom: 25px; font-size: 0.85rem; color: var(--text-muted);">
            <a href="/login" style="color: var(--accent-neon); text-decoration: none;">Sign In</a> to publish feedback.
          </p>
        <% } %>

        <% comments.forEach(comment => { %>
          <div class="comment-card">
            <div class="comment-author">@<%= comment.author %></div>
            <!-- VULNERABILITY: Stored XSS - rendering raw user input as HTML -->
            <div class="comment-content"><%- comment.content %></div>
          </div>
        <% }); %>
      </section>
    </article>
  </div>
</body>
</html>
