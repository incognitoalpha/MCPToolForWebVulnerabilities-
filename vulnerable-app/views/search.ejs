<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>🔓 Search Database | VulnLab</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Orbitron:wght@500;700;900&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-dark: #0a0b10;
      --panel-dark: #12131c;
      --accent-neon: #00f0ff;
      --accent-pink: #ff007f;
      --text-main: #e2e8f0;
      --text-muted: #64748b;
      --border-color: #27273a;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Inter', sans-serif;
    }

    body {
      background-color: var(--bg-dark);
      color: var(--text-main);
      min-height: 100vh;
    }

    header {
      border-bottom: 1px solid var(--border-color);
      background-color: rgba(18, 19, 28, 0.8);
      backdrop-filter: blur(12px);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 15px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .brand {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.6rem;
      font-weight: 900;
      letter-spacing: 2px;
      color: var(--accent-neon);
      text-decoration: none;
    }

    .brand span {
      color: var(--accent-pink);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 25px;
    }

    .nav-links a {
      color: var(--text-main);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.95rem;
      transition: all 0.3s ease;
    }

    .nav-links a:hover {
      color: var(--accent-neon);
    }

    .container {
      max-width: 900px;
      margin: 40px auto;
      padding: 0 20px;
    }

    .section-title {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 25px;
      color: var(--text-main);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .section-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border-color);
    }

    .search-panel {
      background: var(--panel-dark);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 25px;
      margin-bottom: 30px;
    }

    .search-input-group {
      display: flex;
      gap: 10px;
    }

    .cyber-input {
      flex: 1;
      background: rgba(0, 0, 0, 0.2);
      border: 1px solid var(--border-color);
      color: var(--text-main);
      padding: 12px 18px;
      border-radius: 8px;
      font-size: 0.95rem;
      outline: none;
      transition: all 0.3s ease;
    }

    .cyber-input:focus {
      border-color: var(--accent-neon);
    }

    .cyber-button {
      background: var(--accent-neon);
      color: var(--bg-dark);
      border: none;
      padding: 12px 24px;
      border-radius: 8px;
      font-weight: 700;
      cursor: pointer;
      font-family: 'Orbitron', sans-serif;
      transition: all 0.3s ease;
    }

    .cyber-button:hover {
      box-shadow: 0 0 15px rgba(0, 240, 255, 0.4);
    }

    .reflection-banner {
      background: rgba(0, 240, 255, 0.05);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 15px;
      margin-bottom: 30px;
      font-size: 0.95rem;
      border-left: 4px solid var(--accent-neon);
    }

    .reflected-query {
      color: var(--accent-pink);
      font-weight: 600;
      word-break: break-all;
    }

    .post-card {
      background: var(--panel-dark);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 25px;
      margin-bottom: 25px;
      position: relative;
      overflow: hidden;
    }

    .post-card::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 4px;
      background: var(--accent-neon);
    }

    .post-title {
      font-size: 1.3rem;
      font-weight: 600;
      margin-bottom: 10px;
    }

    .post-body {
      color: var(--text-muted);
      line-height: 1.6;
      font-size: 0.95rem;
      margin-bottom: 15px;
    }

    .post-meta {
      display: flex;
      align-items: center;
      gap: 15px;
      font-size: 0.8rem;
      color: var(--text-muted);
      border-top: 1px solid rgba(255, 255, 255, 0.03);
      padding-top: 12px;
    }

    .no-results {
      text-align: center;
      padding: 40px;
      color: var(--text-muted);
      background: var(--panel-dark);
      border: 1px solid var(--border-color);
      border-radius: 12px;
    }
  </style>
</head>
<body>
  <header>
    <div class="header-container">
      <a href="/" class="brand">🔓 VULN<span>LAB</span></a>
      <nav class="nav-links">
        <a href="/">Home</a>
        <a href="/search?q=">Search</a>
        <a href="/tools/ping">Ping System</a>
        <a href="/admin">Admin Control</a>
      </nav>
    </div>
  </header>

  <div class="container">
    <h1 class="section-title">Query Results</h1>

    <div class="search-panel">
      <form action="/search" method="GET">
        <div class="search-input-group">
          <input type="text" name="q" class="cyber-input" placeholder="Search database index..." value="<%= query %>">
          <button type="submit" class="cyber-button">Search</button>
        </div>
      </form>
    </div>

    <% if (query) { %>
      <div class="reflection-banner">
        <!-- VULNERABILITY: Un-sanitized search query printed directly to HTML (Reflected XSS) -->
        Reflected Parameter Match: <span class="reflected-query"><%- query %></span>
      </div>
    <% } %>

    <% if (results.length > 0) { %>
      <% results.forEach(post => { %>
        <article class="post-card">
          <h3 class="post-title"><%= post.title %></h3>
          <p class="post-body"><%= post.content %></p>
          <div class="post-meta">
            <span>By: <strong><%= post.username %></strong></span>
            <span>Date: <strong><%= post.created_at %></strong></span>
          </div>
        </article>
      <% }); %>
    <% } else if (query) { %>
      <div class="no-results">
        No active records matching search index.
      </div>
    <% } %>
  </div>
</body>
</html>
